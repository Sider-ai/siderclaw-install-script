{
  "components": {
    "openclaw-console": {
      "version": "0.7.5",
      "display_name": "OpenClaw Console",
      "binary": "openclaw-console-linux-amd64",
      "service": "openclaw-console",
      "auto_update": true
    },
    "browser-mcp": {
      "version": "0.1.3",
      "display_name": "Browser MCP",
      "binary": "openclaw-browser-mcp-linux-amd64",
      "service": "browser-mcp",
      "auto_update": true,
      "hooks": [
        {
          "file": "openclaw-setup-browser-mcp.sh",
          "args": [
            "single 3000"
          ]
        }
      ]
    },
    "siderclaw-gateway": {
      "version": "0.10.2",
      "display_name": "SiderClaw Gateway",
      "binary": "siderclaw-gateway-linux-amd64",
      "service": "siderclaw-gateway",
      "auto_update": true
    },
    "phone-mcp": {
      "version": "0.0.1",
      "display_name": "Phone MCP",
      "binary": "phone-mcp-server.mjs",
      "service": "phone-mcp-server",
      "runtime": "node",
      "hooks": [
        {
          "file": "openclaw-setup-phone-mcp.sh",
          "args": [
            "{{.OpenclawHome}}/.openclaw/workspace"
          ]
        }
      ]
    }
  },
  "plugins": {
    "chrome-openclaw-sider": {
      "display_name": "Sider Plugin",
      "npm_spec": "chrome-openclaw-sider",
      "auto_update": false
    },
    "test-openclaw-sider": {
      "display_name": "Sider Plugin (Test)",
      "npm_spec": "@hywkp/test-openclaw-sider",
      "auto_update": false
    }
  }
}
